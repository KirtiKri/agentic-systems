   "source": [
    "#Write a program to take marks as input and print grade:\n",
    "\n",
    "marks = int(input(\"Enter your Marks:\"))\n",
    "if marks >= 90:\n",
    "    print(\"Grade A\")\n",
    "elif marks >= 75:\n",
    "    print(\"Grade B\")\n",
    "elif marks >= 50:\n",
    "    print(\"Grade C\")\n",
    "else:\n",
    "    print(\"Fail\")\n",
    "\n"
   ]
  }
